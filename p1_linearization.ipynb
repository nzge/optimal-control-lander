      "source": [
        "# Calculate control energy for Hover\n",
        "energy_integrand_hover = np.sum((u_hover.T @ R) * u_hover.T, axis=1)\n",
        "total_energy_hover = np.trapezoid(energy_integrand_hover, t_hover)\n",
        "\n",
        "# Calculate control energy for Descent\n",
        "energy_integrand_descent = np.sum((u_descent.T @ R) * u_descent.T, axis=1)\n",
        "total_energy_descent = np.trapezoid(energy_integrand_descent, t_descent)\n",
        "\n",
        "print(f\"Hover Control Energy: {total_energy_hover:.2f}\")\n",
        "print(f\"Descent Control Energy: {total_energy_descent:.2f}\")"
      ]
