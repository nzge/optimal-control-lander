      "source": [
        "import numpy as np\n",
        "from scipy.integrate import solve_ivp\n",
        "from scipy.interpolate import interp1d\n",
        "\n",
        "def solve_finite_horizon_lqr(dynamics_func, x0, t_f, Q, R, Qf, params):\n",
        "    \"\"\"\n",
        "    Solves the finite-horizon LQR problem via the Sweep Method.\n",
        "    Works for both LTI (hover) and LTV (descent) systems.\n",
        "    \"\"\"\n",
        "    # Pre-compute R inverse since it's constant\n",
        "    R_inv = np.linalg.inv(R)\n",
        "    \n",
        "    # ==========================================\n",
        "    # 1. BACKWARD PASS: Solve the Riccati ODE\n",
        "    # ==========================================\n",
        "    def riccati_ode(t, P_flat):\n",
        "        \"\"\" ODE for dP/dt. Must be solved backward from t_f to 0 \"\"\"\n",
        "        P = P_flat.reshape((7, 7))\n",
        "        A, B = dynamics_func(t, params)\n",
        "        \n",
        "        # The specific RDE derived from PMP (carrying the factors of 2)\n",
        "        dPdt = -P @ A - A.T @ P + 0.5 * P @ B @ R_inv @ B.T @ P - 2 * Q\n",
        "        return dPdt.flatten()\n",
        "\n",
        "    # Terminal condition derived from transversality: p(t_f) = 2*Qf*x(t_f)\n",
        "    P_tf_flat = (2 * Qf).flatten()\n",
        "    \n",
        "    # Integrate backward from t_f down to 0\n",
        "    print(\"Solving Backward Pass (RDE)...\")\n",
        "    sol_back = solve_ivp(riccati_ode, [t_f, 0], P_tf_flat, dense_output=True)\n",
        "    \n",
        "    # Create an interpolator for P(t) so the forward pass can look it up at any time\n",
        "    # (Note: solve_ivp returns time in descending order here, so we flip it)\n",
        "    t_back = np.flip(sol_back.t)\n",
        "    P_back = np.flip(sol_back.y, axis=1)\n",
        "    P_interp = interp1d(t_back, P_back, axis=1, fill_value=\"extrapolate\")\n",
        "\n",
        "\n",
        "    # ==========================================\n",
        "    # 2. FORWARD PASS: Simulate the Rocket\n",
        "    # ==========================================\n",
        "    def closed_loop_dynamics(t, x):\n",
        "        \"\"\" Forward simulation of the rocket using the optimal gain K(t) \"\"\"\n",
        "        A, B = dynamics_func(t, params)\n",
        "        \n",
        "        # Look up P at this specific time step and reshape it\n",
        "        P_t = P_interp(t).reshape((7, 7))\n",
        "        \n",
        "        # Calculate the optimal gain K(t)\n",
        "        K_t = 0.5 * R_inv @ B.T @ P_t\n",
        "        \n",
        "        # Optimal control law\n",
        "        u_opt = -K_t @ x\n",
        "        \n",
        "        # State derivative\n",
        "        dx_dt = A @ x + B @ u_opt\n",
        "        return dx_dt\n",
        "\n",
        "    print(\"Solving Forward Pass (Simulating Trajectory)...\")\n",
        "    # Evaluate at 500 smooth points for beautiful plotting\n",
        "    t_eval = np.linspace(0, t_f, 500)\n",
        "    sol_forward = solve_ivp(closed_loop_dynamics, [0, t_f], x0, t_eval=t_eval)\n",
        "\n",
        "    # Reconstruct the control history u*(t) for plotting later\n",
        "    u_history = np.zeros((2, len(sol_forward.t)))\n",
        "    for i, t in enumerate(sol_forward.t):\n",
        "        A, B = dynamics_func(t, params)\n",
        "        P_t = P_interp(t).reshape((7, 7))\n",
        "        K_t = 0.5 * R_inv @ B.T @ P_t\n",
        "        u_history[:, i] = -K_t @ sol_forward.y[:, i]\n",
        "        \n",
        "    print(\"Simulation Complete.\\n\")\n",
        "    return sol_forward.t, sol_forward.y, u_history"
      ]
    },
